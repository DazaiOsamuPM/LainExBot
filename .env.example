# Copy to .env and fill in values. Only BOT_TOKEN is required.

# Required: Telegram bot token from @BotFather.
BOT_TOKEN=

# Optional: logging verbosity (DEBUG/INFO/WARNING/ERROR).
LOG_LEVEL=INFO

# Optional: number of concurrent download workers.
MAX_CONCURRENT_DOWNLOADS=3

# Optional: max simultaneous (queued+active) download tasks per user.
MAX_USER_TASKS=2

# Optional: maximum file size to send to Telegram (MB).
# Public Bot API caps at 50 MB. With a self-hosted Bot API Server, up to 2000 MB.
MAX_FILE_SIZE_MB=50

# Optional: per-download timeout (seconds).
DOWNLOAD_TIMEOUT_SECONDS=600

# Optional: self-hosted Telegram Bot API Server URL, e.g. http://localhost:8081
# Leave empty to use the public api.telegram.org.
TELEGRAM_API_BASE=

# Optional: enable tiny HTTP /health endpoint for platforms that require it.
ENABLE_HEALTH_SERVER=false

# Optional: pending inline-link state size per user.
MAX_PENDING_LINKS_PER_USER=20

# Optional: naive per-user rate limit on messages/callbacks.
USER_RATE_LIMIT_MESSAGES=20
USER_RATE_LIMIT_WINDOW_SECONDS=60

# Optional: allow fetching local/private-network URLs in direct-file mode.
# Keep false for public bots to avoid SSRF-style requests.
ALLOW_PRIVATE_URLS=false

# Optional: yt-dlp cookies configuration.
# Path to a Netscape-formatted cookies.txt file:
YTDLP_COOKIES_FILE=
# Or a browser spec: chrome, firefox:default-release, edge::Profile 1
YTDLP_COOKIES_FROM_BROWSER=
